{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clip Studio Presence",
  "version": "0.1.0",
  "identifier": "dev.hiroyko.clip-studio-presence",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clip Studio Presence",
        "width": 920,
        "height": 620,
        "minWidth": 360,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

